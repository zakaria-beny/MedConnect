# MedConnect Environment Variables
# Copy this file to .env and update with your actual values

# JWT Configuration
JWT_SECRET=medconnect-super-secret-key-that-is-at-least-32-chars-long
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# MongoDB
MONGODB_URI=mongodb://mongodb:27017/medconnect

# Email Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# External APIs (Optional - leave empty if not using)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

GOOGLE_CLIENT_ID=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Payment Configuration
SUBSCRIPTION_PAYMENT_PROVIDER=none

# CORS Configuration
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database Configuration (automatically set in docker-compose.yml)
# MYSQL_ROOT_PASSWORD=root
# MYSQL_USER=medconnect
# MYSQL_PASSWORD=medconnect123
# MYSQL_DATABASE=medconnect

# Redis Configuration (automatically set in docker-compose.yml)
# REDIS_HOST=redis
# REDIS_PORT=6379
